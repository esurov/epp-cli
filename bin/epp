#!/usr/bin/env php
<?php

use App\Console\Commands\Epp\ChangePasswordCommand;
use App\Console\Commands\Epp\CheckDomainCommand;
use App\Console\Commands\Epp\CreateContactCommand;
use App\Console\Commands\Epp\CreateDomainCommand;
use App\Console\Commands\Epp\DeleteContactCommand;
use App\Console\Commands\Epp\DeleteDomainCommand;
use App\Console\Commands\Epp\HelloCommand;
use App\Console\Commands\Epp\InfoContactCommand;
use App\Console\Commands\Epp\InfoDomainCommand;
use App\Console\Commands\Epp\PollMessageCommand;
use App\Console\Commands\Epp\TransferCancelDomainCommand;
use App\Console\Commands\Epp\TransferQueryDomainCommand;
use App\Console\Commands\Epp\TransferRequestDomainCommand;
use App\Console\Commands\Epp\UpdateContactCommand;
use App\Console\Commands\Epp\UpdateDomainCommand;
use App\Console\Commands\Epp\WithdrawDomainCommand;
use Symfony\Component\Console\Application;
use Symfony\Component\Console\Command\Command;
use Symfony\Component\Console\Input\ArrayInput;
use Symfony\Component\Console\Input\InputArgument;
use Symfony\Component\Console\Input\InputDefinition;
use Symfony\Component\Console\Input\InputInterface;
use Symfony\Component\Console\Input\InputOption;
use Symfony\Component\Console\Output\OutputInterface;

use function Laravel\Prompts\select;

// Autoloader: support running from source or as a PHAR
foreach ([__DIR__ . '/../vendor/autoload.php', __DIR__ . '/../../autoload.php'] as $file) {
    if (file_exists($file)) {
        require $file;
        break;
    }
}

// Load .env from CWD, or from beside the script/phar
$envPaths = [getcwd()];
$pharPath = Phar::running(false);
if ($pharPath) {
    $envPaths[] = dirname($pharPath);
} else {
    $envPaths[] = dirname(__DIR__);
}
Dotenv\Dotenv::createImmutable($envPaths)->safeLoad();

// Resolve version from git tag
$version = 'dev';
$pharPath = Phar::running(false);
if ($pharPath) {
    // When running as PHAR, version is replaced at build time via Box
    $version = '@git_tag@';
} else {
    $tag = trim((string) shell_exec('git -C ' . escapeshellarg(__DIR__) . ' describe --tags --abbrev=0 2>/dev/null'));
    if ($tag !== '') {
        $version = $tag;
    }
}

// Build the application
$app = new class('EPP CLI', $version) extends Application {
    protected function getDefaultInputDefinition(): InputDefinition
    {
        return new InputDefinition([
            new InputArgument('command', InputArgument::REQUIRED, 'The command to execute'),
            new InputOption('--help', '-h', InputOption::VALUE_NONE, 'Display help for the given command'),
            new InputOption('--silent', null, InputOption::VALUE_NONE, 'Do not output any message'),
            new InputOption('--quiet', '-q', InputOption::VALUE_NONE, 'Only errors are displayed. All other output is suppressed'),
            new InputOption('--verbose', '-v|vv|vvv', InputOption::VALUE_NONE, 'Increase the verbosity of messages: 1 for normal output, 2 for more verbose output and 3 for debug'),
            new InputOption('--version', '-V', InputOption::VALUE_NONE, 'Display this application version'),
            new InputOption('--ansi', '', InputOption::VALUE_NEGATABLE, 'Force (or disable --no-ansi) ANSI output', null),
            new InputOption('--no-interaction', '-n', InputOption::VALUE_NONE, 'Do not ask any interactive question'),
        ]);
    }

    public function doRun(InputInterface $input, OutputInterface $output): int
    {
        // When --help is used without a specific command, show app help + command list
        if ($input->hasParameterOption(['--help', '-h'], true) && ! $input->getFirstArgument()) {
            $output->writeln(<<<'HELP'
<info>EPP CLI</info> - A command-line interface for managing .at domains via EPP.

<comment>Usage:</comment>
  epp-cli <command> [options]

<comment>Examples:</comment>
  epp-cli domain:check --name example.at
  epp-cli domain:info --name example.at
  epp-cli contact:info --id CON-12345

<comment>Get help for a specific command:</comment>
  epp-cli <command> --help

<comment>Run interactively (no arguments):</comment>
  epp-cli
HELP);
            $output->writeln('');

            // Show available commands grouped by namespace
            $builtIn = ['_select', 'help', 'list', 'completion'];
            $grouped = [];
            foreach ($this->all() as $command) {
                $name = $command->getName();
                if (in_array($name, $builtIn) || $command->isHidden()) {
                    continue;
                }
                $parts = explode(':', $name, 2);
                $ns = count($parts) > 1 ? $parts[0] : '';
                $grouped[$ns][$name] = $command->getDescription();
            }
            ksort($grouped);

            $output->writeln('<comment>Available commands:</comment>');
            foreach ($grouped as $ns => $cmds) {
                if ($ns) {
                    $output->writeln(" <comment>$ns</comment>");
                }
                ksort($cmds);
                foreach ($cmds as $name => $desc) {
                    $output->writeln(sprintf('  <info>%-26s</info> %s', $name, $desc));
                }
            }

            $output->writeln('');
            $output->writeln('<comment>Global options:</comment>');
            $output->writeln('  <info>-h, --help</info>       Display help for a command');
            $output->writeln('  <info>-q, --quiet</info>      Suppress all output');
            $output->writeln('  <info>-V, --version</info>    Display version');
            $output->writeln('  <info>-n, --no-interaction</info>  Do not ask any interactive question');
            $output->writeln('  <info>-v|vv|vvv</info>        Increase verbosity');

            return 0;
        }

        return parent::doRun($input, $output);
    }
};

$commands = [
    new HelloCommand,
    new CheckDomainCommand,
    new InfoDomainCommand,
    new CreateDomainCommand,
    new UpdateDomainCommand,
    new DeleteDomainCommand,
    new WithdrawDomainCommand,
    new TransferQueryDomainCommand,
    new TransferRequestDomainCommand,
    new TransferCancelDomainCommand,
    new InfoContactCommand,
    new CreateContactCommand,
    new UpdateContactCommand,
    new DeleteContactCommand,
    new ChangePasswordCommand,
    new PollMessageCommand,
];

$app->addCommands($commands);

// Default command: interactive picker
$default = new class extends Command {
    protected function configure(): void
    {
        $this->setName('_select')->setHidden(true);
    }

    protected function execute(InputInterface $input, OutputInterface $output): int
    {
        /** @var Application $app */
        $app = $this->getApplication();
        $choices = [];

        $builtIn = ['_select', 'help', 'list', 'completion'];
        foreach ($app->all() as $command) {
            $name = $command->getName();
            if (! in_array($name, $builtIn) && ! $command->isHidden()) {
                $choices[$name] = $name . ' - ' . $command->getDescription();
            }
        }

        ksort($choices);

        $selected = select('Select a command:', $choices);

        return $app->find($selected)->run(new ArrayInput([]), $output);
    }
};

$app->add($default);
$app->setDefaultCommand('_select');

$app->run();
