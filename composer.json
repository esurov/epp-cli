{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "nicat/epp-cli",
    "type": "project",
    "description": "A command-line interface for managing .at domains via EPP.",
    "keywords": [
        "epp",
        "cli",
        "nic.at",
        "domain"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-dom": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "laravel/prompts": "^0.3",
        "metaregistrar/php-epp-client": "dev-master",
        "symfony/console": "^7.0|^8.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "humbug/box": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "bin": ["bin/epp"],
    "minimum-stability": "stable",
    "prefer-stable": true
}
